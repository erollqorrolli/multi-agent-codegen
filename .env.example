# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values.
#   cp .env.example .env
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# --- LLM provider (Google AI Studio — free tier) ---
# Get a free key at https://aistudio.google.com/apikey
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-google-ai-studio-key-here

# Models per "tier". The free tier does NOT include gemini-2.5-pro (quota 0),
# so both default to Flash. With a paid plan, set SMART=gemini-2.5-pro.
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-flash

# "Extended thinking" budget (tokens). The smart tier (architect, security)
# gets a larger budget so it reasons harder even on the same model.
LLM_THINKING_BUDGET=1024
LLM_THINKING_BUDGET_SMART=4096

# --- Sandbox (runs the generated tests for real) ---
# auto = use Docker if available, else fall back to a local subprocess runner.
SANDBOX_ENABLED=true
SANDBOX_BACKEND=auto         # auto | docker | local
SANDBOX_TIMEOUT=120

# --- Database ---
# Local dev default matches docker-compose. Override in prod.
DATABASE_URL=postgresql+asyncpg://codegen:codegen@localhost:5432/codegen

# --- GitHub App (fill in once you register the app — see docs/github-app.md) ---
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=./github-app-private-key.pem

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated list of allowed CORS origins for the dashboard.
CORS_ORIGINS=http://localhost:3000
